# Copy to .env and fill in. Do NOT commit .env.
# ---------------------------------------------------------------------------

# Your public hostname (must match the Cloudflare DNS record + Access app).
DOMAIN=openclaw.example.com

# Email for Let's Encrypt expiry notices (optional but recommended).
ACME_EMAIL=you@example.com

# Cloudflare API token used by Caddy for the DNS-01 challenge.
# Create at: Cloudflare dashboard → My Profile → API Tokens → Create Token
#   Template: "Edit zone DNS"
#   Permissions: Zone → DNS → Edit  AND  Zone → Zone → Read
#   Zone Resources: Include → your zone
CLOUDFLARE_API_TOKEN=cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
