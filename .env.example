# Copy to .env and fill in. Do NOT commit .env.
# ---------------------------------------------------------------------------

# OpenClaw hostname (must match its Cloudflare DNS record + Access app).
DOMAIN=openclaw.example.com

# --- Hermes Agent (second domain) ------------------------------------------
# Hermes hostname (its own Cloudflare DNS record + its own Access app).
HERMES_DOMAIN=hermes.example.com
# Hermes dashboard Basic Auth (defense-in-depth behind Cloudflare Access).
HERMES_USER=admin
HERMES_PASSWORD=change-me-to-something-strong

# NOTE: No Cloudflare API token is needed with the Cloudflare Origin Certificate
# approach. (You only need a token if you switch to the Let's Encrypt DNS-01
# method — see caddy/Dockerfile and the README "alternative TLS" note.)
