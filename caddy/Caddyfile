{$DOMAIN} {
	# Cloudflare Origin Certificate (the Cloudflare -> origin leg).
	# Requires Cloudflare SSL/TLS mode = Full (strict) and a proxied (orange) record.
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin-key.pem

	encode zstd gzip

	reverse_proxy openclaw-gateway:18789 {
		# Cloudflare Access authenticates the user at the edge and injects
		# Cf-Access-Authenticated-User-Email. We overwrite any client-supplied
		# X-Forwarded-User with that trusted value (spoof protection).
		header_up X-Forwarded-User {http.request.header.Cf-Access-Authenticated-User-Email}

		# Caddy already sets X-Forwarded-Proto and X-Forwarded-Host by default,
		# which OpenClaw's requiredHeaders expects.
	}
}
